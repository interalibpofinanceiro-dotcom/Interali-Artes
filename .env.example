# Chave GRATUITA da Groq (https://console.groq.com/keys) - sem cartão de
# crédito, ativa a IA de verdade (Onboarding, Copywriter, QA) nos agentes
# CrewAI. Se deixada em branco (e OPENAI_API_KEY também vazia), o sistema
# roda em MODO SIMULADO (respostas heurísticas, sem chamar nenhum LLM).
GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Chave da OpenAI (plano PAGO). Se preenchida, tem prioridade sobre a Groq -
# é o caminho para trocar do teste gratuito para produção sem mudar código,
# só preenchendo esta variável.
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# Banco de dados. Padrão: SQLite local (arquivo interali.db na raiz do projeto).
# Para Postgres em produção, use algo como:
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/interali
DATABASE_URL=sqlite:///interali.db

# Chave gratuita do banco de imagens Pexels (https://www.pexels.com/api/).
# Sem chave configurada, a aba "Banco de Imagens" fica desabilitada e o
# cliente só pode enviar a própria foto/vídeo.
PEXELS_API_KEY=
